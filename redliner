local function w2s(pos)
    local sp, on = Camera:WorldToViewportPoint(pos)
    return Vector2.new(sp.X, sp.Y), on, sp.Z
end

local function newD(kind, props)
    local d = Drawing.new(kind)
    for k,v in pairs(props) do d[k] = v end
    return d
end

local function healthCol(pct)
    local full = Options.HealthFullColor and Options.HealthFullColor.Value or Color3.new(0,1,0)
    local mid  = Options.HealthMidColor  and Options.HealthMidColor.Value  or Color3.fromRGB(255,200,0)
    local low  = Options.HealthLowColor  and Options.HealthLowColor.Value  or Color3.new(1,0,0)
    if pct >= 0.5 then return mid:Lerp(full, (pct - 0.5)*2)
    else               return low:Lerp(mid,  pct*2) end
end

local function clearESP(player)
    local c = espCache[player]
    if not c then return end
    if c.charConn  then c.charConn:Disconnect()  end
    if c.diedConn  then c.diedConn:Disconnect()  end
    local function rm(x)
        if type(x) == "table" then for _,v in pairs(x) do rm(v) end
        elseif x and x.Remove then x:Remove() end
    end
    rm(c.nameText); rm(c.distText)
    rm(c.tracer);   rm(c.boxLines); rm(c.outLines)
    rm(c.hpOut);    rm(c.hpFill)
    rm(c.htOut);    rm(c.htFill)
    rm(c.imOut);    rm(c.imFill)
    rm(c.hpNum);    rm(c.htNum);    rm(c.imNum)
    espCache[player] = nil
end

local function buildESP(player, character, humanoid)
    local c = {}
    c.nameText = newD("Text",   { Center=true, Outline=true,  Visible=false })
    c.distText = newD("Text",   { Center=true, Outline=false, Visible=false })
    c.tracer   = newD("Line",   { Visible=false })
    c.boxLines = {}
    for i=1,8 do c.boxLines[i] = newD("Line",   { Visible=false }) end
    c.outLines = {}
    for i=1,4 do c.outLines[i] = newD("Line",   { Visible=false }) end
    c.hpOut = newD("Square", { Filled=false, Thickness=1, Visible=false })
    c.hpFill= newD("Square", { Filled=true,  Thickness=0, Visible=false })
    c.htOut = newD("Square", { Filled=false, Thickness=1, Visible=false })
    c.htFill= newD("Square", { Filled=true,  Thickness=0, Visible=false })
    c.imOut = newD("Square", { Filled=false, Thickness=1, Visible=false })
    c.imFill= newD("Square", { Filled=true,  Thickness=0, Visible=false })
    c.hpNum  = newD("Text",   { Center=false, Outline=false, Visible=false })
    c.htNum  = newD("Text",   { Center=false, Outline=false, Visible=false })
    c.imNum  = newD("Text",   { Center=false, Outline=false, Visible=false })

    c.charConn = character.AncestryChanged:Connect(function(_,p)
        if not p then clearESP(player) end
    end)
    c.diedConn = humanoid.Died:Connect(function()
        clearESP(player)
    end)

    espCache[player] = c
    return c
end

local function hideESP(c)
    local function h(x)
        if type(x) == "table" then for _,v in pairs(x) do h(v) end
        elseif x and x.Visible ~= nil then x.Visible = false end
    end
    h(c.nameText); h(c.distText)
    h(c.tracer);   h(c.boxLines); h(c.outLines)
    h(c.hpOut);    h(c.hpFill)
    h(c.htOut);    h(c.htFill)
    h(c.imOut);    h(c.imFill)
    h(c.hpNum);    h(c.htNum);    h(c.imNum)
end

local BODY_PARTS = {
    "Head","UpperTorso","LowerTorso","HumanoidRootPart",
    "LeftUpperArm","RightUpperArm","LeftLowerArm","RightLowerArm",
    "LeftHand","RightHand",
    "LeftUpperLeg","RightUpperLeg","LeftLowerLeg","RightLowerLeg",
    "LeftFoot","RightFoot",
    "Torso","Left Arm","Right Arm","Left Leg","Right Leg",
}

local function updatePlayerESP(player, chromaColor)
    local char = player.Character
    if not char then clearESP(player); return end
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    if not hrp then clearESP(player); return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then clearESP(player); return end

    if Toggles.ESPTeamCheck and Toggles.ESPTeamCheck.Value and isTeammate(player) then
        clearESP(player); return
    end

    local stats = getPlayerStats(player)
    if not stats then clearESP(player); return end

    local hpMax    = math.max(stats.health_max      or 1, 1)
    local hp       = math.clamp(stats.health        or 0, 0, hpMax)
    local htMax    = math.max(stats.heat_max        or 1, 1)
    local ht       = math.clamp(stats.heat          or 0, 0, htMax)
    local htPB     = math.max(stats.heat_per_bullet or 1, 1)
    local imLimit  = math.max(stats.impact_limit    or 1, 1)
    local im       = math.clamp(stats.impact        or 0, 0, imLimit)

    local dist    = (Camera.CFrame.Position - hrp.Position).Magnitude
    local maxDist = Options.MaxDist and Options.MaxDist.Value or 500
    if dist > maxDist then
        local c = espCache[player]; if c then hideESP(c) end; return
    end

    local cache = espCache[player] or buildESP(player, char, hum)

    local minX, maxX = math.huge, -math.huge
    local minY, maxY = math.huge, -math.huge
    local found = false

    for _, name in ipairs(BODY_PARTS) do
        local part = char:FindFirstChild(name)
        if part and part:IsA("BasePart") then
            local sz = part.Size
            local cf = part.CFrame
            local hx,hy,hz = sz.X*.5, sz.Y*.5, sz.Z*.5
            for _, off in ipairs({
                Vector3.new( hx, hy, hz), Vector3.new(-hx, hy, hz),
                Vector3.new( hx,-hy, hz), Vector3.new(-hx,-hy, hz),
                Vector3.new( hx, hy,-hz), Vector3.new(-hx, hy,-hz),
                Vector3.new( hx,-hy,-hz), Vector3.new(-hx,-hy,-hz),
            }) do
                local sp, on, depth = w2s(cf:PointToWorldSpace(off))
                if on or depth > 0 then
                    if sp.X < minX then minX = sp.X end
                    if sp.X > maxX then maxX = sp.X end
                    if sp.Y < minY then minY = sp.Y end
                    if sp.Y > maxY then maxY = sp.Y end
                    found = true
                end
            end
        end
    end

    if not found then
        local head    = char:FindFirstChild("Head") or hrp
        local topSP,_,topD  = w2s(head.Position + Vector3.new(0, 0.6, 0))
        local botSP,_,botD  = w2s(hrp.Position  - Vector3.new(0, 2.8, 0))
        local hrpSP,_,hrpD  = w2s(hrp.Position)
        if topD > 0 or botD > 0 or hrpD > 0 then
            minY = topSP.Y; maxY = botSP.Y
            minX = hrpSP.X - 20; maxX = hrpSP.X + 20
        else
            hideESP(cache); return
        end
    end

    local left, right, top, bottom = minX, maxX, minY, maxY

    local refDist  = Options.RefDist and Options.RefDist.Value or 50
    local minScale = Options.MinBarScale and Options.MinBarScale.Value or 0.3
    local maxScale = Options.MaxBarScale and Options.MaxBarScale.Value or 2.0
    local scale    = math.clamp(refDist / math.max(dist, 0.001), minScale, maxScale)

    local barW    = (Options.BarWidth   and Options.BarWidth.Value  or 3)  * scale
    local barH    = (Options.BarHeight  and Options.BarHeight.Value or 32) * scale
    local barGap  = (Options.BarGap     and Options.BarGap.Value    or 3)  * scale
    local barXOff =  Options.BarXOffset and Options.BarXOffset.Value or 5


    local chroma = Toggles.ChromaEnabled and Toggles.ChromaEnabled.Value
    local function cc(chKey, fallback)
        if chroma and Toggles[chKey] and Toggles[chKey].Value then return chromaColor end
        return Options[fallback] and Options[fallback].Value or Color3.new(1,1,1)
    end

    local boxCol  = cc("ChromaBox",    "BoxColor")
    local outCol  = cc("ChromaOutline","OutlineColor")
    local trCol   = cc("ChromaTracer", "TracerColor")
    local nmCol   = cc("ChromaName",   "NameColor")
    local hpCol   = (chroma and Toggles.ChromaHealth and Toggles.ChromaHealth.Value) and chromaColor or healthCol(hp/hpMax)
    local htCol   = cc("ChromaHeat",   "HeatColor")
    local imCol   = cc("ChromaImpact", "ImpactColor")

    local thick  = Options.BoxThickness     and Options.BoxThickness.Value     or 1.5
    local oThick = Options.OutlineThickness and Options.OutlineThickness.Value or 3
    local fSize  = Options.FontSize         and Options.FontSize.Value         or 13


    if Toggles.ShowBox and Toggles.ShowBox.Value then
        local useCorners = Toggles.CornersOnly and Toggles.CornersOnly.Value
        local cl = (right - left) * 0.28
        if useCorners then
            local segs = {
                {Vector2.new(left,  top),    Vector2.new(left+cl,  top)},
                {Vector2.new(left,  top),    Vector2.new(left,     top+cl)},
                {Vector2.new(right, top),    Vector2.new(right-cl, top)},
                {Vector2.new(right, top),    Vector2.new(right,    top+cl)},
                {Vector2.new(left,  bottom), Vector2.new(left+cl,  bottom)},
                {Vector2.new(left,  bottom), Vector2.new(left,     bottom-cl)},
                {Vector2.new(right, bottom), Vector2.new(right-cl, bottom)},
                {Vector2.new(right, bottom), Vector2.new(right,    bottom-cl)},
            }
            for i,s in ipairs(segs) do
                cache.boxLines[i].From      = s[1]
                cache.boxLines[i].To        = s[2]
                cache.boxLines[i].Color     = boxCol
                cache.boxLines[i].Thickness = thick
                cache.boxLines[i].Visible   = true
            end
        else
            local segs = {
                {Vector2.new(left,  top),    Vector2.new(right, top)},
                {Vector2.new(right, top),    Vector2.new(right, bottom)},
                {Vector2.new(right, bottom), Vector2.new(left,  bottom)},
                {Vector2.new(left,  bottom), Vector2.new(left,  top)},
            }
            for i,s in ipairs(segs) do
                cache.boxLines[i].From      = s[1]
                cache.boxLines[i].To        = s[2]
                cache.boxLines[i].Color     = boxCol
                cache.boxLines[i].Thickness = thick
                cache.boxLines[i].Visible   = true
            end
            for i = 5,8 do cache.boxLines[i].Visible = false end
        end
    else
        for i = 1,8 do cache.boxLines[i].Visible = false end
    end


    if Toggles.ShowOutline and Toggles.ShowOutline.Value then
        local p = 1
        local segs = {
            {Vector2.new(left-p,  top-p),    Vector2.new(right+p, top-p)},
            {Vector2.new(right+p, top-p),    Vector2.new(right+p, bottom+p)},
            {Vector2.new(right+p, bottom+p), Vector2.new(left-p,  bottom+p)},
            {Vector2.new(left-p,  bottom+p), Vector2.new(left-p,  top-p)},
        }
        for i,s in ipairs(segs) do
            cache.outLines[i].From      = s[1]
            cache.outLines[i].To        = s[2]
            cache.outLines[i].Color     = outCol
            cache.outLines[i].Thickness = oThick
            cache.outLines[i].Visible   = true
        end
    else
        for _,l in ipairs(cache.outLines) do l.Visible = false end
    end


    if Toggles.ShowName and Toggles.ShowName.Value then
        local head = char:FindFirstChild("Head")
        local headScreen, headOnScreen = head and Camera:WorldToViewportPoint(head.Position)
        local headY = headOnScreen and headScreen.Y or top
        cache.nameText.Text     = player.DisplayName
        cache.nameText.Position = Vector2.new((left+right)*.5, headY - fSize - 2)
        cache.nameText.Color    = nmCol
        cache.nameText.Size     = fSize
        cache.nameText.Visible  = true
    else
        cache.nameText.Visible = false
    end

    if Toggles.ShowTracers and Toggles.ShowTracers.Value then
        local vp    = Camera.ViewportSize
        local hrpSP = w2s(hrp.Position)
        cache.tracer.From      = Vector2.new(vp.X*.5, vp.Y)
        cache.tracer.To        = Vector2.new(hrpSP.X, bottom)
        cache.tracer.Color     = trCol
        cache.tracer.Thickness = Options.TracerThickness and Options.TracerThickness.Value or 1
        cache.tracer.Visible   = true
    else
        cache.tracer.Visible = false
    end

    local function drawBar(outD, fillD, xPos, yTop, pct, fillCol)
        local fill = barH * math.clamp(pct, 0, 1)
        outD.Position  = Vector2.new(xPos - 1,       yTop - 1)
        outD.Size      = Vector2.new(barW + 2,        barH + 2)
        outD.Color     = Color3.new(0, 0, 0)
        outD.Visible   = true
        fillD.Position = Vector2.new(xPos,            yTop + barH - fill)
        fillD.Size     = Vector2.new(barW,            fill)
        fillD.Color    = fillCol
        fillD.Visible  = fill > 0
    end

    local numSize = math.max(fSize - 2, 9)
    local function setBarNum(numText, xPos, yMid, cur, max, col)
        numText.Text     = string.format("%.0f/%.0f", cur, max)
        numText.Position = Vector2.new(xPos, yMid - numSize/2)
        numText.Color    = col
        numText.Size     = numSize
        numText.Visible  = true
    end

    if Toggles.ShowHealth and Toggles.ShowHealth.Value then
        local xHP = left - barXOff - barW
        drawBar(cache.hpOut, cache.hpFill, xHP, top, hp / hpMax, hpCol)
        setBarNum(cache.hpNum, xHP - 2 - numSize*3, top + barH/2, hp, hpMax, hpCol)
    else
        cache.hpOut.Visible = false; cache.hpFill.Visible = false
        cache.hpNum.Visible = false
    end

    if Toggles.ShowHeat and Toggles.ShowHeat.Value then
        local maxB = math.floor(htMax / htPB)
        local htPct = math.floor(ht / htPB) / math.max(maxB, 1)
        local xHeat = right + barXOff
        drawBar(cache.htOut, cache.htFill, xHeat, top, htPct, htCol)
        setBarNum(cache.htNum, xHeat + barW + 2, top + barH/2,
                  math.floor(ht / htPB), math.floor(htMax / htPB), htCol)
    else
        cache.htOut.Visible = false; cache.htFill.Visible = false
        cache.htNum.Visible = false
    end

    if Toggles.ShowImpact and Toggles.ShowImpact.Value then
        local yImp = Toggles.ShowHeat and Toggles.ShowHeat.Value and (top + barH + barGap) or top
        local xImp = right + barXOff
        drawBar(cache.imOut, cache.imFill, xImp, yImp, im / imLimit, imCol)
        setBarNum(cache.imNum, xImp + barW + 2, yImp + barH/2, im, imLimit, imCol)
    else
        cache.imOut.Visible = false; cache.imFill.Visible = false
        cache.imNum.Visible = false
    end

    if Toggles.ShowDistance and Toggles.ShowDistance.Value then
        cache.distText.Text     = string.format("%.0fm", dist)
        cache.distText.Position = Vector2.new((left+right)*.5, bottom + 4)
        cache.distText.Color    = Color3.new(0.85, 0.85, 0.85)
        cache.distText.Size     = math.max(fSize - 2, 9)
        cache.distText.Visible  = true
    else
        cache.distText.Visible = false
    end
end

