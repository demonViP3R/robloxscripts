local function isUserInputType(name)
	return name == "MouseButton1" or name == "MouseButton2" or name == "MouseButton3" or name:sub(1, 2) == "MB"
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end
	if Options.KeybindMode.Value ~= "Toggle" then
		return
	end

	local keyData = Options.AimlockKey
	local targetKey = keyData.Value
	local modifiers = keyData.Modifiers or {}
	local matches = false

	if isUserInputType(targetKey) then
		local success, targetEnum = pcall(function()
			return Enum.UserInputType[targetKey]
		end)
		if success and targetEnum and input.UserInputType == targetEnum then
			local allModsHeld = true
			for _, mod in ipairs(modifiers) do
				if not UserInputService:IsKeyDown(Enum.KeyCode[mod]) then
					allModsHeld = false
					break
				end
			end
			if allModsHeld then
				matches = true
			end
		end
	else
		local success, targetEnum = pcall(function()
			return Enum.KeyCode[targetKey]
		end)
		if success and targetEnum and input.KeyCode == targetEnum then
			local allModsHeld = true
			for _, mod in ipairs(modifiers) do
				if not UserInputService:IsKeyDown(Enum.KeyCode[mod]) then
					allModsHeld = false
					break
				end
			end
			if allModsHeld then
				matches = true
			end
		end
	end

	if matches then
		AimlockToggleState = not AimlockToggleState
		StatusLabel:SetText(AimlockToggleState and "Status: Active" or "Status: Inactive")
	end
end)

local function getTargetPart(entity, partName)
	local hurtboxes = entity:FindFirstChild("Hurtboxes")
	if not hurtboxes then
		return nil
	end
	if partName == "Head" then
		return hurtboxes:FindFirstChild("Head_Hurtbox")
	elseif partName == "HumanoidRootPart" then
		return hurtboxes:FindFirstChild("HumanoidRootPart_Hurtbox")
	end
	return nil
end

local function isTeammate(player)
	if player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team then
		return true
	end
	return false
end

local function isVisible(targetPart)
	local origin = Camera.CFrame.Position
	local direction = (targetPart.Position - origin).Unit * (targetPart.Position - origin).Magnitude

	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude

	local excludeList = { LocalPlayer.Character }

	local entityModel = targetPart
	while entityModel and entityModel.Parent ~= workspace.Entities do
		entityModel = entityModel.Parent
	end
	if entityModel and entityModel:IsA("Model") then
		table.insert(excludeList, entityModel)
	end

	raycastParams.FilterDescendantsInstances = excludeList

	local result = workspace:Raycast(origin, direction, raycastParams)
	return result == nil
end

local function findClosestAimTarget()
	local fov = Options.FOV.Value
	local maxDist = Options.MaxDistance.Value
	local targetPartName = Options.TargetPart.Value
	local teamCheck = Toggles.TeamCheck.Value
	local wallCheck = Toggles.WallCheck and Toggles.WallCheck.Value
	local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local bestPart = nil
	local bestDistToCenter = math.huge

	local entitiesFolder = workspace:FindFirstChild("Entities")
	if not entitiesFolder then
		return nil
	end

	for _, entity in ipairs(entitiesFolder:GetChildren()) do
		if entity:IsA("Model") then
			local humanoid = entity:FindFirstChildWhichIsA("Humanoid")
			if humanoid and humanoid.Health > 0 then
				local owner = Players:GetPlayerFromCharacter(entity)
				if owner then
					if owner == LocalPlayer then
						continue
					end
					if teamCheck and isTeammate(owner) then
						continue
					end
				end
				local part = getTargetPart(entity, targetPartName)
				if part and part:IsA("BasePart") then
					if wallCheck and not isVisible(part) then
						continue
					end
					local distance = (Camera.CFrame.Position - part.Position).Magnitude
					if distance <= maxDist then
						local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
						if onScreen then
							local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
							if screenDist <= fov and screenDist < bestDistToCenter then
								bestDistToCenter = screenDist
								bestPart = part
							end
						end
					end
				end
			end
		end
	end
	return bestPart
end

local function performAutoAttack()
	if not Toggles.AutoAttackEnabled.Value then
		return
	end
	local range = Options.AutoAttackRange.Value
	local cooldown = Options.AutoAttackCooldown.Value
	local now = tick()
	if now - LastAttackTime < cooldown then
		return
	end

	local teamCheck = Toggles.TeamCheck.Value
	local entitiesFolder = workspace:FindFirstChild("Entities")
	if not entitiesFolder then
		return
	end

	local playerRootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not playerRootPart then
		return
	end

	local closestDistance = math.huge
	local closestEntity = nil

	for _, entity in ipairs(entitiesFolder:GetChildren()) do
		if entity:IsA("Model") then
			local humanoid = entity:FindFirstChildWhichIsA("Humanoid")
			if humanoid and humanoid.Health > 0 then
				local owner = Players:GetPlayerFromCharacter(entity)
				if owner then
					if owner == LocalPlayer then
						continue
					end
					if teamCheck and isTeammate(owner) then
						continue
					end
				end
				local rootPart = entity:FindFirstChild("HumanoidRootPart") or entity.PrimaryPart
				if rootPart and rootPart:IsA("BasePart") then
					local distance = (playerRootPart.Position - rootPart.Position).Magnitude
					if distance <= range and distance < closestDistance then
						closestDistance = distance
						closestEntity = entity
					end
				end
			end
		end
	end

	if closestEntity then
		LastAttackTime = now
		local screenCenterX = Camera.ViewportSize.X / 2
		local screenCenterY = Camera.ViewportSize.Y / 2
		VirtualInputManager:SendMouseButtonEvent(screenCenterX, screenCenterY, 0, true, game, 1)
		task.wait(0.01)
		VirtualInputManager:SendMouseButtonEvent(screenCenterX, screenCenterY, 0, false, game, 1)
	end
end

local GlareDelayKeys = {
	["MonarchGlare"] = "MonarchGlareDelay",
	["PhoenixGlare"] = "PhoenixGlareDelay",
	["SiegeGlare"] = "SiegeGlareDelay",
	["Cross"] = "CrossDelay",
	["ParryIndicator"] = "ParryIndicatorDelay",
	["SlideAttack"] = "SlideAttackDelay",
	["Attack2"] = "Attack2Delay",
	["Attack1"] = "Attack1Delay",
