local function pressParryKey()
	local parryKey = Options.ParryKey.Value
	if not parryKey then
		return
	end
	local success, keyEnum = pcall(function()
		return Enum.KeyCode[parryKey]
	end)
	if success and keyEnum then
		VirtualInputManager:SendKeyEvent(true, keyEnum, false, game)
		task.wait(0.1)
		VirtualInputManager:SendKeyEvent(false, keyEnum, false, game)
	end
end

local function doublePressParryKey()
	pressParryKey()
	local gap = Options.DoublePressGap and Options.DoublePressGap.Value or 0.3
	task.wait(gap)
	pressParryKey()
end

local function isEnemyInParryDistance()
	if not Toggles.ParryDistanceCheck or not Toggles.ParryDistanceCheck.Value then
		return true
	end

	local dist = Options.ParryDistance and Options.ParryDistance.Value or 500
	local playerRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not playerRoot then
		return false
	end

	local entitiesFolder = workspace:FindFirstChild("Entities")
	if not entitiesFolder then
		return true
	end

	for _, entity in ipairs(entitiesFolder:GetChildren()) do
		if entity:IsA("Model") then
			local humanoid = entity:FindFirstChildWhichIsA("Humanoid")
			if humanoid and humanoid.Health > 0 then
				local owner = Players:GetPlayerFromCharacter(entity)
				if owner then
					if owner == LocalPlayer then
						continue
					end
					if Toggles.TeamCheck and Toggles.TeamCheck.Value and isTeammate(owner) then
						continue
					end
				end
				local rootPart = entity:FindFirstChild("HumanoidRootPart") or entity.PrimaryPart
				if rootPart and rootPart:IsA("BasePart") then
					if (playerRoot.Position - rootPart.Position).Magnitude <= dist then
						return true
					end
				end
			end
		end
	end
	return false
end

local function onGlareAppeared(glare, glareName)
	if ParryWatching then
		return
	end
	ParryWatching = true

	local ancestryConnection
	ancestryConnection = glare.AncestryChanged:Connect(function(_, newParent)
		if newParent == nil then
			ParryWatching = false
			if ancestryConnection then
				ancestryConnection:Disconnect()
			end
		end
	end)

	local delayKey = GlareDelayKeys[glareName]
	local delay = delayKey and Options[delayKey] and Options[delayKey].Value or 1

	task.wait(delay)

	if isEnemyInParryDistance() then
		if glareName == "SiegeGlare" then
			doublePressParryKey()
		else
			pressParryKey()
		end
	end

	ParryWatching = false
	if ancestryConnection then
		ancestryConnection:Disconnect()
	end
end

local function setupParryDetection()
	local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
	local VisualEffects = PlayerGui:WaitForChild("VisualEffects")

	if parryGlareConnection then
		parryGlareConnection:Disconnect()
	end

	parryGlareConnection = VisualEffects.ChildAdded:Connect(function(child)
		if GlareDelayKeys[child.Name] and child:IsA("GuiObject") then
			onGlareAppeared(child, child.Name)
		end
	end)

	for _, child in ipairs(VisualEffects:GetChildren()) do
		if GlareDelayKeys[child.Name] and child:IsA("GuiObject") then
			onGlareAppeared(child, child.Name)
		end
	end
end

function StartParryWatcher()
	if ParryWatcherRunning then
		return
	end
	ParryWatcherRunning = true

	local conn
	conn = RunService.Heartbeat:Connect(function()
		if LocalPlayer:FindFirstChild("PlayerGui") and LocalPlayer.PlayerGui:FindFirstChild("VisualEffects") then
			setupParryDetection()
			conn:Disconnect()
		end
	end)
end

function StopParryWatcher()
	ParryWatcherRunning = false
	if parryGlareConnection then
		parryGlareConnection:Disconnect()
		parryGlareConnection = nil
	end
	ParryWatching = false
end

