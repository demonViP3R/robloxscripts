        rainbowHue = (rainbowHue + (Options.ChromaSpeed.Value * dt * 0.1)) % 1
        rainbowColor = Color3.fromHSV(rainbowHue, 1, 1)
        applyWorldChroma(rainbowColor)
    else
        rainbowColor = nil
    end

    local fov = Options.FOV.Value
