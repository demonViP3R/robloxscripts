end

local function worldToScreen(pos)
	local screenPos, onScreen = Camera:WorldToViewportPoint(pos)
	return Vector2.new(screenPos.X, screenPos.Y), onScreen
end

local function createDrawing(type, properties)
	local drawing = Drawing.new(type)
	for k, v in pairs(properties) do
		drawing[k] = v
	end
	return drawing
end

local function clearPlayerESP(player)
	if espCache[player] then
		local cache = espCache[player]

		if cache.ancestryConnection then
			cache.ancestryConnection:Disconnect()
		end
		if cache.diedConnection then
			cache.diedConnection:Disconnect()
		end

		for _, drawing in pairs(cache) do
			if type(drawing) == "table" then
				for _, d in pairs(drawing) do
					if d.Remove then
						d:Remove()
					end
				end
			else
				if drawing.Remove then
					drawing:Remove()
				end
			end
		end

		if cache.renderStepName then
			RunService:UnbindFromRenderStep(cache.renderStepName)
		end
		espCache[player] = nil
	end
end

local function updatePlayerESP(player, rainbowColor)
	local character = player.Character
	if not character then
		clearPlayerESP(player)
		return
	end
	local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoidRootPart then
		clearPlayerESP(player)
		return
	end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		clearPlayerESP(player)
		return
	end

	if Toggles.ESPTeamCheck and Toggles.ESPTeamCheck.Value and isTeammate(player) then
		clearPlayerESP(player)
		return
	end

	local stats = getPlayerStats(player)
	if not stats then
		clearPlayerESP(player)
		return
	end

	if not espCache[player] then
		espCache[player] = {}
	end
	local cache = espCache[player]

	if not cache.nameText then
		cache.nameText = createDrawing("Text", { Size = Options.FontSize.Value, Center = true, Outline = true })
		cache.hpLeft = createDrawing("Text", { Size = Options.FontSize.Value - 2, Center = false, Outline = false })
		cache.hpRight = createDrawing("Text", { Size = Options.FontSize.Value - 2, Center = false, Outline = false })
		cache.infoText = createDrawing("Text", { Size = Options.FontSize.Value - 2, Center = true, Outline = false })

		cache.boxLines = {
			c1 = createDrawing("Line", { Thickness = Options.BoxThickness.Value }),
			c2 = createDrawing("Line", { Thickness = Options.BoxThickness.Value }),
			c3 = createDrawing("Line", { Thickness = Options.BoxThickness.Value }),
			c4 = createDrawing("Line", { Thickness = Options.BoxThickness.Value }),
			c5 = createDrawing("Line", { Thickness = Options.BoxThickness.Value }),
			c6 = createDrawing("Line", { Thickness = Options.BoxThickness.Value }),
			c7 = createDrawing("Line", { Thickness = Options.BoxThickness.Value }),
			c8 = createDrawing("Line", { Thickness = Options.BoxThickness.Value }),
		}

		cache.hpOut = createDrawing("Square", { Filled = false, Thickness = 1 })
		cache.hpBar = createDrawing("Square", { Filled = true, Thickness = 0 })

		cache.heatOut = createDrawing("Square", { Filled = false, Thickness = 1 })
		cache.heatBar = createDrawing("Square", { Filled = true, Thickness = 0 })

		cache.tracer = createDrawing("Line", { Thickness = Options.TracerThickness.Value })

		cache.outlineLines = {
			top = createDrawing("Line", { Thickness = Options.OutlineThickness.Value }),
			bottom = createDrawing("Line", { Thickness = Options.OutlineThickness.Value }),
			left = createDrawing("Line", { Thickness = Options.OutlineThickness.Value }),
			right = createDrawing("Line", { Thickness = Options.OutlineThickness.Value }),
		}

		cache.ancestryConnection = character.AncestryChanged:Connect(function(_, p)
			if not p then
				clearPlayerESP(player)
			end
		end)
		cache.diedConnection = humanoid.Died:Connect(function()
			clearPlayerESP(player)
		end)
	end

	local rootPos = humanoidRootPart.Position
	local head = character:FindFirstChild("Head")
	local headPos = head and head.Position or rootPos + Vector3.new(0, 3, 0)
	local screenRoot, onScreen = worldToScreen(rootPos)
	local screenHead, headOnScreen = worldToScreen(headPos)

	if not onScreen and not headOnScreen then
		for _, d in pairs(cache) do
			if type(d) == "table" then
				for _, v in pairs(d) do
					if v.Visible ~= nil then
						v.Visible = false
					end
				end
			elseif d.Visible ~= nil then
				d.Visible = false
			end
		end
		return
	end

	local distance = (Camera.CFrame.Position - rootPos).Magnitude
	local referenceDist = Options.ESPDistanceReference and Options.ESPDistanceReference.Value or 50
	local scale = math.clamp(referenceDist / math.max(distance, 1), 0.3, 3.0)

	local chromaEnabled = Toggles["Eli's mode <3 ;3"] and Toggles["Eli's mode <3 ;3"].Value
	local boxColor = (chromaEnabled and Toggles.ChromaBox and Toggles.ChromaBox.Value) and rainbowColor
		or (Options.BoxColor.Value or Color3.new(1, 1, 1))
	local outlineColor = (chromaEnabled and Toggles.ChromaOutline and Toggles.ChromaOutline.Value) and rainbowColor
		or (Options.OutlineColor.Value or Color3.new(0, 0, 0))
	local tracerColor = (chromaEnabled and Toggles.ChromaTracer and Toggles.ChromaTracer.Value) and rainbowColor
		or (Options.TracerColor.Value or Color3.new(1, 1, 1))
	local nameColor = (chromaEnabled and Toggles.ChromaName and Toggles.ChromaName.Value) and rainbowColor
		or (Options.NameColor.Value or Color3.new(1, 1, 1))
	local healthFullColor = Options.HealthFullColor.Value or Color3.new(0, 1, 0)
	local healthLowColor = Options.HealthLowColor.Value or Color3.new(1, 0, 0)
	local healthBarColor = (chromaEnabled and Toggles.ChromaHealth and Toggles.ChromaHealth.Value) and rainbowColor
		or (
			stats.health
				and stats.health_max
				and healthFullColor:Lerp(healthLowColor, 1 - math.clamp(stats.health / stats.health_max, 0, 1))
			or healthFullColor
		)
	local heatColor = (chromaEnabled and Toggles.ChromaHeat and Toggles.ChromaHeat.Value) and rainbowColor
		or (Options.HeatColor.Value or Color3.fromRGB(255, 100, 0))
	local impactColor = (chromaEnabled and Toggles.ChromaImpact and Toggles.ChromaImpact.Value) and rainbowColor
		or (Options.ImpactColor.Value or Color3.new(1, 1, 1))

	local characterSize = character:GetExtentsSize()
	local topY = (headPos - rootPos).Magnitude
	local bottomY = (rootPos - (rootPos - Vector3.new(0, characterSize.Y / 2, 0))).Magnitude
	local topScreen, _ = worldToScreen(rootPos + Vector3.new(0, topY, 0))
	local bottomScreen, _ = worldToScreen(rootPos - Vector3.new(0, bottomY, 0))
	local height = (topScreen.Y - bottomScreen.Y)
	local width = height * 0.4
	local left = screenRoot.X - width / 2
	local right = screenRoot.X + width / 2

	if Toggles.ShowBox and Toggles.ShowBox.Value then
		local useCorners = Toggles.CornersOnly and Toggles.CornersOnly.Value
		local boxThickness = Options.BoxThickness.Value
		if useCorners then
			local cl = width * 0.25
			cache.boxLines.c1.From = Vector2.new(left, topScreen.Y)
			cache.boxLines.c1.To = Vector2.new(left + cl, topScreen.Y)
			cache.boxLines.c1.Color = boxColor
			cache.boxLines.c1.Thickness = boxThickness
			cache.boxLines.c1.Visible = true

			cache.boxLines.c2.From = Vector2.new(left, topScreen.Y)
			cache.boxLines.c2.To = Vector2.new(left, topScreen.Y + cl)
			cache.boxLines.c2.Color = boxColor
			cache.boxLines.c2.Thickness = boxThickness
			cache.boxLines.c2.Visible = true

			cache.boxLines.c3.From = Vector2.new(right, topScreen.Y)
			cache.boxLines.c3.To = Vector2.new(right - cl, topScreen.Y)
			cache.boxLines.c3.Color = boxColor
			cache.boxLines.c3.Thickness = boxThickness
			cache.boxLines.c3.Visible = true

			cache.boxLines.c4.From = Vector2.new(right, topScreen.Y)
			cache.boxLines.c4.To = Vector2.new(right, topScreen.Y + cl)
			cache.boxLines.c4.Color = boxColor
			cache.boxLines.c4.Thickness = boxThickness
			cache.boxLines.c4.Visible = true

			cache.boxLines.c5.From = Vector2.new(left, bottomScreen.Y)
			cache.boxLines.c5.To = Vector2.new(left + cl, bottomScreen.Y)
			cache.boxLines.c5.Color = boxColor
			cache.boxLines.c5.Thickness = boxThickness
			cache.boxLines.c5.Visible = true

			cache.boxLines.c6.From = Vector2.new(left, bottomScreen.Y)
			cache.boxLines.c6.To = Vector2.new(left, bottomScreen.Y - cl)
			cache.boxLines.c6.Color = boxColor
			cache.boxLines.c6.Thickness = boxThickness
			cache.boxLines.c6.Visible = true

			cache.boxLines.c7.From = Vector2.new(right, bottomScreen.Y)
			cache.boxLines.c7.To = Vector2.new(right - cl, bottomScreen.Y)
			cache.boxLines.c7.Color = boxColor
			cache.boxLines.c7.Thickness = boxThickness
			cache.boxLines.c7.Visible = true

			cache.boxLines.c8.From = Vector2.new(right, bottomScreen.Y)
			cache.boxLines.c8.To = Vector2.new(right, bottomScreen.Y - cl)
			cache.boxLines.c8.Color = boxColor
			cache.boxLines.c8.Thickness = boxThickness
			cache.boxLines.c8.Visible = true
		else
			for _, v in pairs(cache.boxLines) do
				v.Visible = false
			end
		end
	else
		for _, v in pairs(cache.boxLines) do
			v.Visible = false
		end
	end

	if Toggles.ShowOutline and Toggles.ShowOutline.Value then
		local outlineThickness = Options.OutlineThickness.Value or 3
		local pad = 2
		cache.outlineLines.top.From = Vector2.new(left - pad, topScreen.Y - pad)
		cache.outlineLines.top.To = Vector2.new(right + pad, topScreen.Y - pad)
		cache.outlineLines.bottom.From = Vector2.new(left - pad, bottomScreen.Y + pad)
		cache.outlineLines.bottom.To = Vector2.new(right + pad, bottomScreen.Y + pad)
		cache.outlineLines.left.From = Vector2.new(left - pad, bottomScreen.Y + pad)
		cache.outlineLines.left.To = Vector2.new(left - pad, topScreen.Y - pad)
		cache.outlineLines.right.From = Vector2.new(right + pad, bottomScreen.Y + pad)
		cache.outlineLines.right.To = Vector2.new(right + pad, topScreen.Y - pad)
		for _, v in pairs(cache.outlineLines) do
			v.Color = outlineColor
			v.Thickness = outlineThickness
			v.Visible = true
		end
	else
		for _, v in pairs(cache.outlineLines) do
			v.Visible = false
		end
	end

	if Toggles.ShowName and Toggles.ShowName.Value then
		local nameText = player.DisplayName
		cache.nameText.Text = nameText
		cache.nameText.Position = Vector2.new(screenRoot.X, (headOnScreen and screenHead.Y or screenRoot.Y) - 20)
		cache.nameText.Color = nameColor
		cache.nameText.Size = Options.FontSize.Value
		cache.nameText.Visible = true
	else
		cache.nameText.Visible = false
	end

	if Toggles.ShowTracers and Toggles.ShowTracers.Value then
		cache.tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
		cache.tracer.To = screenRoot
		cache.tracer.Color = tracerColor
		cache.tracer.Thickness = Options.TracerThickness.Value
		cache.tracer.Visible = true
	else
		cache.tracer.Visible = false
	end

	if Toggles.ShowHealth and Toggles.ShowHealth.Value and stats.health_max and stats.health then
		local barWidth = Options.BarWidth.Value * scale
		local barHeight = Options.BarHeight.Value * scale
		local barOffset = Options.BarOffset.Value * scale
		local healthPercent = math.clamp(stats.health / stats.health_max, 0, 1)
		local yStart = headOnScreen and screenHead.Y or screenRoot.Y
		local yEnd = yStart + barHeight

		cache.hpOut.Size = Vector2.new(barWidth + 2, barHeight + 2)
		cache.hpOut.Position = Vector2.new(left - barWidth - barOffset - 1, yStart - 1)
		cache.hpOut.Color = (chromaEnabled and Toggles.ChromaHealth and Toggles.ChromaHealth.Value) and rainbowColor
			or Color3.new(1, 1, 1)
		cache.hpOut.Visible = true

		local hpFill = barHeight * healthPercent
		cache.hpBar.Size = Vector2.new(barWidth, hpFill)
		cache.hpBar.Position = Vector2.new(left - barWidth - barOffset, yEnd - hpFill)
		cache.hpBar.Color = healthBarColor
		cache.hpBar.Visible = true

		cache.hpLeft.Text = string.format("%.0f", stats.health)
		cache.hpLeft.Position = Vector2.new(left + 2, yStart + 2)
		cache.hpLeft.Color = (chromaEnabled and Toggles.ChromaHealth and Toggles.ChromaHealth.Value) and rainbowColor
			or Color3.new(1, 1, 1)
		cache.hpLeft.Size = Options.FontSize.Value - 2
		cache.hpLeft.Visible = true

		cache.hpRight.Text = string.format("%.0f", stats.health_max)
		cache.hpRight.Position = Vector2.new(right - 2 - 20, yStart + 2)
		cache.hpRight.Color = (chromaEnabled and Toggles.ChromaHealth and Toggles.ChromaHealth.Value) and rainbowColor
			or Color3.new(1, 1, 1)
		cache.hpRight.Size = Options.FontSize.Value - 2
		cache.hpRight.Visible = true
	else
		cache.hpOut.Visible = false
		cache.hpBar.Visible = false
		cache.hpLeft.Visible = false
		cache.hpRight.Visible = false
	end

	if Toggles.ShowHeat and Toggles.ShowHeat.Value and stats.heat_max and stats.heat and stats.heat_per_bullet then
		local barWidth = Options.BarWidth.Value * scale
		local barHeight = Options.BarHeight.Value * scale
		local barOffset = Options.BarOffset.Value * scale
		local heatPerBullet = stats.heat_per_bullet
		local maxBullets = heatPerBullet > 0 and math.floor(stats.heat_max / heatPerBullet) or 0
		local currentBullets = heatPerBullet > 0 and math.floor(stats.heat / heatPerBullet) or 0
		local heatPercent = maxBullets > 0 and math.clamp(currentBullets / maxBullets, 0, 1) or 0
		local yStart = headOnScreen and screenHead.Y or screenRoot.Y
		local yEnd = yStart + barHeight

		cache.heatOut.Size = Vector2.new(barWidth + 2, barHeight + 2)
		cache.heatOut.Position = Vector2.new(right + barOffset - 1, yStart - 1)
		cache.heatOut.Color = (chromaEnabled and Toggles.ChromaHeat and Toggles.ChromaHeat.Value) and rainbowColor
			or Color3.new(1, 1, 1)
		cache.heatOut.Visible = true

		local heatFill = barHeight * heatPercent
		cache.heatBar.Size = Vector2.new(barWidth, heatFill)
		cache.heatBar.Position = Vector2.new(right + barOffset, yEnd - heatFill)
		cache.heatBar.Color = heatColor
		cache.heatBar.Visible = true
	else
		cache.heatOut.Visible = false
		cache.heatBar.Visible = false
	end

	if Toggles.ShowImpact and Toggles.ShowImpact.Value and stats.impact and stats.impact_limit then
		local impactText = string.format("Impact: %.0f/%.0f", stats.impact, stats.impact_limit)
		cache.infoText.Text = impactText
		cache.infoText.Position = Vector2.new(screenRoot.X, bottomScreen.Y + 4)
		cache.infoText.Color = impactColor
		cache.infoText.Size = Options.FontSize.Value - 2
		cache.infoText.Visible = true
	elseif Toggles.ShowDistance and Toggles.ShowDistance.Value then
		local distText = string.format("%.0fm", distance)
		cache.infoText.Text = distText
		cache.infoText.Position = Vector2.new(screenRoot.X, bottomScreen.Y + 4)
		cache.infoText.Color = (chromaEnabled and Toggles.ChromaImpact and Toggles.ChromaImpact.Value) and rainbowColor
			or Color3.new(1, 1, 1)
		cache.infoText.Size = Options.FontSize.Value - 2
		cache.infoText.Visible = true
	else
		cache.infoText.Visible = false
	end
end

local function snapshotChromaElement(key)
	if key == "ambient" and not snapshotTaken.ambient then
		chromaSnapshot.ambient = Lighting.Ambient
		snapshotTaken.ambient = true
	elseif key == "outdoorAmbient" and not snapshotTaken.outdoorAmbient then
		chromaSnapshot.outdoorAmbient = Lighting.OutdoorAmbient
		snapshotTaken.outdoorAmbient = true
	elseif key == "fog" and not snapshotTaken.fog then
		chromaSnapshot.fog = Lighting.FogColor
		snapshotTaken.fog = true
	elseif key == "colorShift" and not snapshotTaken.colorShift then
		pcall(function()
			local top = Lighting:FindFirstChild("ColorShift_Top")
			if top then
				chromaSnapshot.colorShiftTop = top.Value
			end
		end)
		pcall(function()
			local bottom = Lighting:FindFirstChild("ColorShift_Bottom")
			if bottom then
				chromaSnapshot.colorShiftBottom = bottom.Value
			end
		end)
		snapshotTaken.colorShift = true
	elseif key == "clouds" and not snapshotTaken.clouds then
		local terrain = workspace:FindFirstChild("Terrain")
		if terrain then
			local clouds = terrain:FindFirstChild("Clouds")
			if clouds and clouds:IsA("Model") then
				for _, part in ipairs(clouds:GetDescendants()) do
					if part:IsA("BasePart") then
						table.insert(chromaSnapshot.clouds, { part = part, color = part.Color })
					end
				end
			end
		end
		snapshotTaken.clouds = true
	elseif key == "camera" and not snapshotTaken.camera then
		chromaSnapshot.cameraObjects = {}
		local function collect(obj)
			for _, child in ipairs(obj:GetChildren()) do
				local hasColor, color = pcall(function()
					return child.Color
				end)
				if hasColor then
					table.insert(chromaSnapshot.cameraObjects, { obj = child, prop = "Color", original = color })
				else
					local hasBg, bgColor = pcall(function()
						return child.BackgroundColor3
					end)
					if hasBg then
						table.insert(
							chromaSnapshot.cameraObjects,
							{ obj = child, prop = "BackgroundColor3", original = bgColor }
						)
					end
				end
				collect(child)
			end
		end
		pcall(function()
			local hasCamBg, camBg = pcall(function()
				return Camera.BackgroundColor3
			end)
			if hasCamBg then
				table.insert(
					chromaSnapshot.cameraObjects,
					{ obj = Camera, prop = "BackgroundColor3", original = camBg }
				)
			end
			collect(Camera)
		end)
		snapshotTaken.camera = true
	end
end

local function applyWorldChroma(color)
	if Toggles.ChromaAmbient and Toggles.ChromaAmbient.Value then
		snapshotChromaElement("ambient")
		pcall(function()
			Lighting.Ambient = color
		end)
	elseif snapshotTaken.ambient then
		pcall(function()
			Lighting.Ambient = chromaSnapshot.ambient
		end)
	end
	if Toggles.ChromaOutdoorAmbient and Toggles.ChromaOutdoorAmbient.Value then
		snapshotChromaElement("outdoorAmbient")
		pcall(function()
			Lighting.OutdoorAmbient = color
		end)
	elseif snapshotTaken.outdoorAmbient then
		pcall(function()
			Lighting.OutdoorAmbient = chromaSnapshot.outdoorAmbient
		end)
	end
	if Toggles.ChromaFog and Toggles.ChromaFog.Value then
		snapshotChromaElement("fog")
		pcall(function()
			Lighting.FogColor = color
		end)
	elseif snapshotTaken.fog then
		pcall(function()
			Lighting.FogColor = chromaSnapshot.fog
		end)
	end
	if Toggles.ChromaColorShift and Toggles.ChromaColorShift.Value then
		snapshotChromaElement("colorShift")
		pcall(function()
			local top = Lighting:FindFirstChild("ColorShift_Top")
			if top then
				top.Value = color
			end
		end)
		pcall(function()
			local bottom = Lighting:FindFirstChild("ColorShift_Bottom")
			if bottom then
				bottom.Value = color
			end
		end)
	elseif snapshotTaken.colorShift then
		pcall(function()
			local top = Lighting:FindFirstChild("ColorShift_Top")
			if top then
				top.Value = chromaSnapshot.colorShiftTop
			end
		end)
		pcall(function()
			local bottom = Lighting:FindFirstChild("ColorShift_Bottom")
			if bottom then
				bottom.Value = chromaSnapshot.colorShiftBottom
			end
		end)
	end
	if Toggles.ChromaClouds and Toggles.ChromaClouds.Value then
		snapshotChromaElement("clouds")
		for _, entry in ipairs(chromaSnapshot.clouds) do
			pcall(function()
				entry.part.Color = color
			end)
		end
	elseif snapshotTaken.clouds then
		for _, entry in ipairs(chromaSnapshot.clouds) do
			pcall(function()
				entry.part.Color = entry.color
			end)
		end
	end
	if Toggles.ChromaCamera and Toggles.ChromaCamera.Value then
		snapshotChromaElement("camera")
		for _, entry in ipairs(chromaSnapshot.cameraObjects) do
			if entry.prop == "Color" then
				pcall(function()
					entry.obj.Color = color
				end)
			else
				pcall(function()
					entry.obj.BackgroundColor3 = color
				end)
			end
		end
	elseif snapshotTaken.camera then
		for _, entry in ipairs(chromaSnapshot.cameraObjects) do
			if entry.prop == "Color" then
				pcall(function()
					entry.obj.Color = entry.original
				end)
			else
				pcall(function()
					entry.obj.BackgroundColor3 = entry.original
				end)
			end
		end
	end
end

local function restoreAllChroma()
	if snapshotTaken.ambient then
		pcall(function()
			Lighting.Ambient = chromaSnapshot.ambient
		end)
	end
	if snapshotTaken.outdoorAmbient then
		pcall(function()
			Lighting.OutdoorAmbient = chromaSnapshot.outdoorAmbient
		end)
	end
	if snapshotTaken.fog then
		pcall(function()
			Lighting.FogColor = chromaSnapshot.fog
		end)
	end
	if snapshotTaken.colorShift then
		pcall(function()
			local top = Lighting:FindFirstChild("ColorShift_Top")
			if top then
				top.Value = chromaSnapshot.colorShiftTop
			end
		end)
		pcall(function()
			local bottom = Lighting:FindFirstChild("ColorShift_Bottom")
			if bottom then
				bottom.Value = chromaSnapshot.colorShiftBottom
			end
		end)
	end
	if snapshotTaken.clouds then
		for _, entry in ipairs(chromaSnapshot.clouds) do
			pcall(function()
				entry.part.Color = entry.color
			end)
		end
	end
	if snapshotTaken.camera then
		for _, entry in ipairs(chromaSnapshot.cameraObjects) do
			if entry.prop == "Color" then
				pcall(function()
					entry.obj.Color = entry.original
				end)
			else
				pcall(function()
					entry.obj.BackgroundColor3 = entry.original
				end)
			end
		end
	end
	for k in pairs(snapshotTaken) do
		snapshotTaken[k] = false
	end
	chromaSnapshot.clouds = {}
	chromaSnapshot.cameraObjects = {}
end

RunService.RenderStepped:Connect(function()
	local chromaNow = Toggles["Eli's mode <3 ;3"] and Toggles["Eli's mode <3 ;3"].Value
	if chromaNow and not chromaWasEnabled then
	elseif not chromaNow and chromaWasEnabled then
		restoreAllChroma()
	end
	chromaWasEnabled = chromaNow

	local rainbowColor
	if chromaNow then
		rainbowHue = (rainbowHue + (Options.ChromaSpeed.Value * 0.005)) % 1
		rainbowColor = Color3.fromHSV(rainbowHue, 1, 1)
		applyWorldChroma(rainbowColor)
	else
		rainbowColor = nil
	end

	local fov = Options.FOV.Value
	FOVCircle.Radius = fov
	FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	FOVCircle.Visible = Toggles.ShowFOV.Value
	if chromaNow and Toggles.ChromaFOVCircle and Toggles.ChromaFOVCircle.Value then
		FOVCircle.Color = rainbowColor
	else
		FOVCircle.Color = Options.FOVColor.Value or Color3.new(1, 1, 1)
	end

	performAutoAttack()
	updateParryHurtboxSize()
	updateHitboxExtender()
	performBunnyHop()
	performAutoDash()

	if Toggles.ESPEnabled.Value then
		for _, player in ipairs(Players:GetPlayers()) do
			if player == LocalPlayer then
				continue
			end
			updatePlayerESP(player, rainbowColor or Color3.new(1, 1, 1))
		end

		for player, _ in pairs(espCache) do
			if player ~= LocalPlayer and not player.Parent then
				clearPlayerESP(player)
			end
		end
	else
		for _, cache in pairs(espCache) do
			for _, drawing in pairs(cache) do
				if type(drawing) == "table" then
					for _, d in pairs(drawing) do
						if d.Visible ~= nil then
							d.Visible = false
						end
					end
				elseif drawing.Visible ~= nil then
					drawing.Visible = false
				end
			end
		end
	end

	if not Toggles.AimlockEnabled.Value then
		AimPart = nil
		StatusLabel:SetText("Status: Disabled")
		return
	end

	local shouldAim = false
	local mode = Options.KeybindMode.Value
	if mode == "Hold" then
		shouldAim = Options.AimlockKey:GetState()
	elseif mode == "Toggle" then
		shouldAim = AimlockToggleState
	end

	StatusLabel:SetText(shouldAim and "Status: Active" or "Status: Inactive")

	if not shouldAim then
		AimPart = nil
		return
	end

	local part = findClosestAimTarget()
	AimPart = part

	if AimPart then
		local smooth = Options.Smoothing.Value
		local lookAt = CFrame.new(Camera.CFrame.Position, AimPart.Position)
		Camera.CFrame = Camera.CFrame:Lerp(lookAt, smooth)
	end
end)

