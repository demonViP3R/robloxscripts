local function updateParryHurtboxSize()
	if not Toggles.ExpandParryHitbox then
		if lastParryHurtboxPart and originalParryHurtboxSize then
			lastParryHurtboxPart.Size = originalParryHurtboxSize
		end
		lastParryHurtboxPart = nil
		originalParryHurtboxSize = nil
		return
	end

	local part = getParryHurtbox()
	if part and part:IsA("BasePart") then
		if part ~= lastParryHurtboxPart then
			originalParryHurtboxSize = part.Size
			lastParryHurtboxPart = part
		end
		local multiplier = Options.ParryHitboxMultiplier.Value
		part.Size = originalParryHurtboxSize * multiplier
	else
		lastParryHurtboxPart = nil
		originalParryHurtboxSize = nil
	end
end

local function getHitboxPart(partName)
	local char = LocalPlayer.Character
	if not char then
		return nil
	end
	local entity = workspace.Entities:FindFirstChild(LocalPlayer.Name)
	if not entity then
		return nil
	end
	local hurtboxes = entity:FindFirstChild("Hurtboxes")
	if not hurtboxes then
		return nil
	end
	return hurtboxes:FindFirstChild(partName)
end

local function updateHitboxExtender()
	if not Toggles.HitboxExtenderEnabled then
		for part, originalSize in pairs(extendedHitboxes) do
			pcall(function()
				part.Size = originalSize
			end)
		end
		extendedHitboxes = {}
		return
	end

	local multiplier = Options.HitboxExtenderMultiplier.Value
	local newExtended = {}

	for _, partName in ipairs(hitboxExtenderParts) do
		local part = getHitboxPart(partName)
		if part and part:IsA("BasePart") then
			if not extendedHitboxes[part] then
				extendedHitboxes[part] = part.Size
			end
			newExtended[part] = extendedHitboxes[part]
			part.Size = extendedHitboxes[part] * multiplier
		end
	end

	for part, originalSize in pairs(extendedHitboxes) do
		if not newExtended[part] then
			pcall(function()
				part.Size = originalSize
			end)
		end
	end
	extendedHitboxes = newExtended
end

local function isPlayerMoving()
	return UserInputService:IsKeyDown(Enum.KeyCode.W)
		or UserInputService:IsKeyDown(Enum.KeyCode.A)
		or UserInputService:IsKeyDown(Enum.KeyCode.S)
		or UserInputService:IsKeyDown(Enum.KeyCode.D)
		or UserInputService:IsKeyDown(Enum.KeyCode.Up)
		or UserInputService:IsKeyDown(Enum.KeyCode.Down)
		or UserInputService:IsKeyDown(Enum.KeyCode.Left)
		or UserInputService:IsKeyDown(Enum.KeyCode.Right)
end

local function performBunnyHop()
	if not Toggles.BunnyHopEnabled.Value then
		return
	end
	if not LocalPlayer.Character then
		return
	end

	local isMoving = isPlayerMoving()
	if Toggles.MovementDebug and Toggles.MovementDebug.Value then
		print("[BunnyHop] Enabled:", Toggles.BunnyHopEnabled.Value, "Moving:", isMoving)
	end

	if not isMoving then
		return
	end

	local now = tick()
	local delay = Options.BunnyHopDelay and Options.BunnyHopDelay.Value or 0.1
	if now - LastBunnyHopTime < delay then
		return
	end

	LastBunnyHopTime = now

	local holdTime = Options.BunnyHopHoldTime and Options.BunnyHopHoldTime.Value or 0.05
	local releaseGap = Options.BunnyHopReleaseGap and Options.BunnyHopReleaseGap.Value or 0.02

	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftControl, false, game)
	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
	task.wait(holdTime)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
	task.wait(releaseGap)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)

	if Toggles.MovementDebug and Toggles.MovementDebug.Value then
		print("[BunnyHop] Hopped! (hold=" .. holdTime .. ", gap=" .. releaseGap .. ")")
	end
end

local function performAutoDash()
	if not Toggles.AutoDashEnabled.Value then
		return
	end
	if not LocalPlayer.Character then
		return
	end

	local isMoving = isPlayerMoving()
	if Toggles.MovementDebug and Toggles.MovementDebug.Value then
		print("[AutoDash] Enabled:", Toggles.AutoDashEnabled.Value, "Moving:", isMoving)
	end

	if not isMoving then
		return
	end

	local now = tick()
	local delay = Options.DashDelay and Options.DashDelay.Value or 0.2
	if now - LastDashTime < delay then
		return
	end

	LastDashTime = now

	local dashKey = Options.DashKey.Value
	if not dashKey then
		return
	end
	local success, keyEnum = pcall(function()
		return Enum.KeyCode[dashKey]
	end)
	if success and keyEnum then
		VirtualInputManager:SendKeyEvent(true, keyEnum, false, game)
		task.wait(0.1)
		VirtualInputManager:SendKeyEvent(false, keyEnum, false, game)
		if Toggles.MovementDebug and Toggles.MovementDebug.Value then
			print("[AutoDash] Dashed with key:", dashKey)
		end
	else
		if Toggles.MovementDebug and Toggles.MovementDebug.Value then
			print("[AutoDash] Invalid key:", dashKey)
		end
	end
end

local function getPlayerStats(player)
	if player and player:FindFirstChild("ReadOnly") then
		local ro = player.ReadOnly
		return {
			health_max = ro:FindFirstChild("health_max") and ro.health_max.Value,
			health = ro:FindFirstChild("health") and ro.health.Value,
