-- Helpers
local function getDiceIdFromLabel()
    local ok, text = pcall(function()
        return LocalPlayer.PlayerGui.MainGui.DiceHolder.MainDiceFrame.DiceButton.DiceNameLabel.Text
    end)
    if not ok or not text then return nil end
    if nameToId[text] then return nameToId[text] end
    local formatted = text:lower():gsub("%s+", "_")
    for _, id in ipairs(allDiceIds) do
        if id == formatted then return id end
    end
    return nil
end

-- Collect ALL folders named "Slots" anywhere inside a parent
local function findAllSlots(parent, results)
    results = results or {}
    for _, child in ipairs(parent:GetChildren()) do
        if child.Name == "Slots" and child:IsA("Folder") then
            table.insert(results, child)
        end
        findAllSlots(child, results)
    end
    return results
end

local function getClosestPlot()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local hrp = char.HumanoidRootPart

    local closestPlot, minDist = nil, math.huge
    for _, plot in ipairs(Plots:GetChildren()) do
        local ok, pivot = pcall(function() return plot:GetPivot().Position end)
        if ok then
            local d = (hrp.Position - pivot).Magnitude
            if d < minDist then minDist = d; closestPlot = plot end
        end
    end

    if not closestPlot then return nil end
    return #findAllSlots(closestPlot) > 0 and closestPlot or nil
end

local function getSelectedDice(dropdownKey)
    local opt = Options[dropdownKey]
    if not opt then return {} end
    local selected = opt.Value
    if selected["all"] then return allDiceIds end
    local result = {}
    for id, enabled in pairs(selected) do
        if enabled then table.insert(result, id) end
    end
    return result
end

