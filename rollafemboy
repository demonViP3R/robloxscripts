-- Automation loops
task.spawn(function()  -- Auto Buy
    while true do
        if Toggles.AutoBuy.Value then
            for _, id in ipairs(getSelectedDice("AutoBuyDice")) do
                buyEvent:FireServer(id, false)
                task.wait(0.1)
            end
        end
        task.wait(0.5)
    end
end)

task.spawn(function()  -- Auto Open
    while true do
        if Toggles.AutoOpen.Value then
            for _, id in ipairs(getSelectedDice("AutoOpenDice")) do
                rollEvent:FireServer(id)
                task.wait(0.1)
            end
        end
        task.wait(1)
    end
end)

task.spawn(function()  -- Smart Roll
    while true do
        if Toggles.SmartRoll.Value then
            local id = getDiceIdFromLabel()
            if id then
                rollEvent:FireServer(id)
            else
                warn("[SmartRoll] Could not read dice label or match a known id")
            end
        end
        task.wait(0.7)
    end
end)

task.spawn(function()  -- Auto Collect
    while true do
        if Toggles.AutoCollect.Value then
            local plot = getClosestPlot()
            if plot then
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, slotsFolder in ipairs(findAllSlots(plot)) do
                        for _, slot in ipairs(slotsFolder:GetChildren()) do
                            local collecter = slot:FindFirstChild("Collecter", true)
                            local btn = collecter and collecter:FindFirstChild("Button")
                            local touch = btn and btn:FindFirstChild("TouchInterest")
                            if btn and touch then
                                firetouchinterest(hrp, btn, true)
                                task.wait(0.01)
                                firetouchinterest(hrp, btn, false)
                            end
                        end
                    end
                end
            end
        end
        task.wait(0.5)
    end
end)

task.spawn(function()  -- Auto Hatch
    while true do
        if Toggles.AutoHatch.Value then
            local egg = Options.AutoHatchEgg.Value
            if type(egg) == "table" then
                for k, _ in pairs(egg) do egg = k; break end
            end
            if type(egg) == "string" and egg ~= "" then
                local petName, petMult = nil, nil
                pcall(function()
                    local result = hatchEvent:InvokeServer(egg)
                    for k, v in pairs(result) do
                        if tostring(k) == "pet" then
                            for k2, v2 in pairs(v) do
                                local key = tostring(k2)
                                local val = tostring(v2)
                                if key == "Name" then petName = val end
                                if key == "Multiplier" then petMult = val end
                            end
                        end
                    end
                end)
                if petName then
                    Library:Notify({
                        Title = "Hatched!",
                        Content = petName .. " (" .. (petMult or "?") .. "x)",
                        Duration = 3,
                    })
                end
            end
        end
        task.wait(1)
    end
end)

task.spawn(function()  -- Auto Sell
    while true do
        if Toggles.AutoSell.Value then
            autoEquipEvent:FireServer()
            task.wait(0.5)
            sellEvent:FireServer(true)
            local delaySeconds = Options.AutoSellDelay.Value * 60
            local elapsed = 0
            while elapsed < delaySeconds and Toggles.AutoSell.Value do
                task.wait(1)
                elapsed += 1
            end
        else
            task.wait(1)
        end
    end
end)

task.spawn(function()  -- Auto Skip
    while true do
        if Toggles.AutoSkip.Value then
            local RollGui = LocalPlayer.PlayerGui:FindFirstChild("RollGui")
            if RollGui and RollGui.Enabled then
                local skip = RollGui:FindFirstChild("Holder")
                    and RollGui.Holder:FindFirstChild("Buttons")
                    and RollGui.Holder.Buttons:FindFirstChild("Skip")
                if skip then firesignal(skip.MouseButton1Click) end
            end
        end
        task.wait(0.1)
    end
end)

task.spawn(function()  -- Anti AFK
    LocalPlayer.Idled:Connect(function()
