-- Auto Buy loop
task.spawn(function()
    while true do
        if Toggles.AutoBuy.Value then
            for _, diceId in ipairs(getSelectedDice("AutoBuyDice")) do
                Event:FireServer(diceId, false)
                task.wait(0.1)
            end
        end
        task.wait(0.5)
    end
end)

-- Auto Open loop
