local function getDiceIdFromLabel()
    local success, result = pcall(function()
        return Players.LocalPlayer.PlayerGui.MainGui.DiceHolder.MainDiceFrame.DiceButton.DiceNameLabel.Text
    end)
    if not success or not result then return nil end

    local id = nameToId[result]
    if id then return id end

    local formatted = result:lower():gsub("%s+", "_")
    for _, knownId in ipairs(allDiceIds) do
        if knownId == formatted then
            return knownId
        end
    end

    return nil
end

local function getClosestPlot()
    local character = Players.LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    local hrp = character.HumanoidRootPart
    local closestPlot, closestDistance = nil, math.huge
    for _, plot in ipairs(Plots:GetChildren()) do
        if plot:FindFirstChild("Slots") then
            local distance = (hrp.Position - plot:GetPivot().Position).Magnitude
            if distance < closestDistance then
                closestDistance = distance
                closestPlot = plot
            end
        end
    end
    return closestPlot
end

local function getSelectedDice(dropdownKey)
    local selected = Options[dropdownKey].Value
    if selected["all"] then
        return allDiceIds
    end
    local result = {}
    for diceId, enabled in pairs(selected) do
        if enabled then
            table.insert(result, diceId)
        end
    end
    return result
end

