task.spawn(function()
    while true do
        if Toggles.AutoBuy.Value then
            local selected = Options.AutoBuyDice.Value
            for diceId, enabled in pairs(selected) do
                if enabled then
                    Event:FireServer(diceId, false)
                    task.wait(0.1)
                end
            end
        end
        task.wait(0.5)
    end
end)

task.spawn(function()
    while true do
        if Toggles.AutoOpen.Value then
            local selected = Options.AutoOpenDice.Value
            for diceId, enabled in pairs(selected) do
                if enabled then
                    event2:FireServer(diceId)
                    task.wait(0.1)
                end
            end
        end
        task.wait(1)
    end
end)

task.spawn(function()
    while true do
        if Toggles.AutoCollect.Value then
            local closestPlot = getClosestPlot()
            if closestPlot and closestPlot:FindFirstChild("Slots") then
                for _, slot in ipairs(closestPlot.Slots:GetChildren()) do
                    if slot:FindFirstChild("Collecter") and slot.Collecter:FindFirstChild("Button") then
                        local character = Players.LocalPlayer.Character
                        if character and character:FindFirstChild("HumanoidRootPart") then
                            local hrp = character.HumanoidRootPart
                            firetouchinterest(hrp, slot.Collecter.Button, true)
                            task.wait(0.01)
                            firetouchinterest(hrp, slot.Collecter.Button, false)
                        end
                    end
                end
            end
        end
        task.wait(0.5)
    end
end)

task.spawn(function()
    while true do
        if Toggles.AutoSell.Value then
            autoEquipEvent:FireServer()
            task.wait(0.5)
            sellEvent:FireServer(true)
            local delaySeconds = Options.AutoSellDelay.Value * 60
            local elapsed = 0
            while elapsed < delaySeconds do
                task.wait(1)
                elapsed = elapsed + 1
                if not Toggles.AutoSell.Value then break end
            end
        else
            task.wait(1)
        end
    end
end)

task.spawn(function()
    while true do
        if Toggles.AutoSkip.Value then
            local RollGui = Players.LocalPlayer.PlayerGui:FindFirstChild("RollGui")
            if RollGui and RollGui.Enabled then
                local button = RollGui:FindFirstChild("Holder")
                    and RollGui.Holder:FindFirstChild("Buttons")
                    and RollGui.Holder.Buttons:FindFirstChild("Skip")
                if button then
                    firesignal(button.MouseButton1Click)
                end
            end
        end
        task.wait(0.1)
    end
end)


