function UnloadScript()
    for _, conn in ipairs(connections) do
        pcall(function() conn:Disconnect() end)
    end
    connections = {}
    if mainLoopConnection then
        pcall(function() mainLoopConnection:Disconnect() end)
        mainLoopConnection = nil
    end
    StopParryWatcher()
    restoreAllChroma()
    for player, _ in pairs(espCache) do
        clearESP(player)
    end
    espCache = {}
    if FOVCircle then
        FOVCircle:Remove()
        FOVCircle = nil
    end
    print("Matcha Universal Script unloaded successfully!")
end

