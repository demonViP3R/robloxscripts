    local char = LocalPlayer.Character
    if not char then return nil end
    local entity = workspace.Entities:FindFirstChild(LocalPlayer.Name)
    if not entity then return nil end
    local hurtboxes = entity:FindFirstChild("Hurtboxes")
    if not hurtboxes then return nil end
    return hurtboxes:FindFirstChild(partName)
end

local function updateHitboxExtender()
    if not getVal("HitboxExtenderEnabled") then
        for part, originalSize in pairs(extendedHitboxes) do
            pcall(function() part.Size = originalSize end)
        end
        extendedHitboxes = {}
        return
    end

    local multiplier = getVal("HitboxExtenderMultiplier") or 2.0
    local newExtended = {}

    for _, partName in ipairs(hitboxExtenderParts) do
        local part = getHitboxPart(partName)
        if part and part:IsA("BasePart") then
            if not extendedHitboxes[part] then
                extendedHitboxes[part] = part.Size
            end
            newExtended[part] = extendedHitboxes[part]
            part.Size = extendedHitboxes[part] * multiplier
        end
    end

    for part, originalSize in pairs(extendedHitboxes) do
        if not newExtended[part] then
            pcall(function() part.Size = originalSize end)
        end
    end
    extendedHitboxes = newExtended
end

