local function snapshotChromaElement(key)
    if snapshotTaken[key] then return end
    if key == "ambient" then
        chromaSnapshot.ambient = Lighting.Ambient
    elseif key == "outdoorAmbient" then
        chromaSnapshot.outdoorAmbient = Lighting.OutdoorAmbient
    elseif key == "fog" then
        chromaSnapshot.fog = Lighting.FogColor
    elseif key == "colorShift" then
        pcall(function()
            local top = Lighting:FindFirstChild("ColorShift_Top")
            if top then chromaSnapshot.colorShiftTop = top.Value end
        end)
        pcall(function()
            local bottom = Lighting:FindFirstChild("ColorShift_Bottom")
            if bottom then chromaSnapshot.colorShiftBottom = bottom.Value end
        end)
    elseif key == "clouds" then
        chromaSnapshot.clouds = {}
        local terrain = workspace:FindFirstChildOfClass("Terrain")
        if terrain then
            local clouds = terrain:FindFirstChild("Clouds")
            if clouds and clouds:IsA("Model") then
                for _, p in ipairs(clouds:GetDescendants()) do
                    if p:IsA("BasePart") then
                        table.insert(chromaSnapshot.clouds, { part = p, color = p.Color })
                    end
                end
            end
        end
    elseif key == "camera" then
        chromaSnapshot.cameraObjects = {}
        local function collect(obj)
            for _, child in ipairs(obj:GetChildren()) do
                local ok, val = pcall(function() return child.Color end)
                if ok then
                    table.insert(chromaSnapshot.cameraObjects, { obj = child, prop = "Color", original = val })
                else
                    local ok2, val2 = pcall(function() return child.BackgroundColor3 end)
                    if ok2 then
                        table.insert(chromaSnapshot.cameraObjects, { obj = child, prop = "BackgroundColor3", original = val2 })
                    end
                end
                collect(child)
            end
        end
        pcall(collect, Camera)
    end
    snapshotTaken[key] = true
end

local function restoreChromaElement(key)
    if not snapshotTaken[key] then return end
    if key == "ambient" then
        pcall(function() Lighting.Ambient = chromaSnapshot.ambient end)
    elseif key == "outdoorAmbient" then
        pcall(function() Lighting.OutdoorAmbient = chromaSnapshot.outdoorAmbient end)
    elseif key == "fog" then
        pcall(function() Lighting.FogColor = chromaSnapshot.fog end)
    elseif key == "colorShift" then
        pcall(function()
            local top = Lighting:FindFirstChild("ColorShift_Top")
            if top then top.Value = chromaSnapshot.colorShiftTop end
        end)
        pcall(function()
            local bottom = Lighting:FindFirstChild("ColorShift_Bottom")
            if bottom then bottom.Value = chromaSnapshot.colorShiftBottom end
        end)
    elseif key == "clouds" then
        for _, e in ipairs(chromaSnapshot.clouds) do
            pcall(function() e.part.Color = e.color end)
        end
    elseif key == "camera" then
        for _, e in ipairs(chromaSnapshot.cameraObjects) do
            if e.prop == "Color" then
                pcall(function() e.obj.Color = e.original end)
            else
                pcall(function() e.obj.BackgroundColor3 = e.original end)
            end
        end
    end
end

function restoreAllChroma()
    for key in pairs(snapshotTaken) do
        restoreChromaElement(key)
        snapshotTaken[key] = false
    end
    chromaSnapshot.clouds = {}
    chromaSnapshot.cameraObjects = {}
end

local function applyWorldChroma(color)
    local function apply(chromaToggle, key, setFn)
        if getVal(chromaToggle) then
            snapshotChromaElement(key)
            pcall(setFn, color)
        elseif snapshotTaken[key] then
            restoreChromaElement(key)
            snapshotTaken[key] = false
        end
    end

    apply("ChromaAmbient",        "ambient",        function(c) Lighting.Ambient = c end)
    apply("ChromaOutdoorAmbient", "outdoorAmbient", function(c) Lighting.OutdoorAmbient = c end)
    apply("ChromaFog",            "fog",            function(c) Lighting.FogColor = c end)

    if getVal("ChromaColorShift") then
        snapshotChromaElement("colorShift")
        pcall(function()
            local t = Lighting:FindFirstChild("ColorShift_Top")
            if t then t.Value = color end
        end)
        pcall(function()
            local b = Lighting:FindFirstChild("ColorShift_Bottom")
            if b then b.Value = color end
        end)
    elseif snapshotTaken.colorShift then
        restoreChromaElement("colorShift")
        snapshotTaken.colorShift = false
    end

    if getVal("ChromaClouds") then
        snapshotChromaElement("clouds")
        for _, e in ipairs(chromaSnapshot.clouds) do
            pcall(function() e.part.Color = color end)
        end
    elseif snapshotTaken.clouds then
        restoreChromaElement("clouds")
        snapshotTaken.clouds = false
    end

    if getVal("ChromaCamera") then
        snapshotChromaElement("camera")
        for _, e in ipairs(chromaSnapshot.cameraObjects) do
            if e.prop == "Color" then
                pcall(function() e.obj.Color = color end)
            else
                pcall(function() e.obj.BackgroundColor3 = color end)
            end
        end
    elseif snapshotTaken.camera then
        restoreChromaElement("camera")
        snapshotTaken.camera = false
    end
end

mainLoopConnection = RunService.RenderStepped:Connect(function(dt)
    local chromaNow = getVal("ChromaEnabled")
    if chromaNow and not chromaWasEnabled then
    elseif not chromaNow and chromaWasEnabled then
        restoreAllChroma()
    end
    chromaWasEnabled = chromaNow

    local rainbowColor
    if chromaNow then
        rainbowHue = (rainbowHue + (getVal("ChromaSpeed") or 1) * dt * 0.1) % 1
        rainbowColor = Color3.fromHSV(rainbowHue, 1, 1)
        applyWorldChroma(rainbowColor)
    else
        rainbowColor = nil
    end

    local fov = getVal("FOV") or 150
    FOVCircle.Radius = fov
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Visible = getVal("ShowFOV")
    if chromaNow and getVal("ChromaFOVCircle") then
        FOVCircle.Color = rainbowColor
    else
        FOVCircle.Color = getVal("FOVColor") or Color3.new(1,1,1)
    end

    performAutoAttack()
    updateParryHurtboxSize()
    updateHitboxExtender()
    performAutoDash()

    if getVal("ESPEnabled") then
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            updatePlayerESP(player, rainbowColor or Color3.new(1,1,1))
        end
        for player in pairs(espCache) do
            if not player.Parent then clearESP(player) end
        end
    else
        for _, cache in pairs(espCache) do
            hideESP(cache)
        end
    end

    local aimEnabled = getVal("AimlockEnabled")
    if not aimEnabled then
        AimPart = nil
        if AimStatusLabel then AimStatusLabel:SetText("Status: Disabled") end
        return
    end

    local keyObj = Keybinds.Aimlock
    local shouldAim = false
    if keyObj then
        if getVal("KeybindMode") == 0 then
            shouldAim = keyObj:IsEnabled()
        else
            shouldAim = AimlockToggleState
        end
    end

    if AimStatusLabel then
        AimStatusLabel:SetText(shouldAim and "Status: Active" or "Status: Inactive")
    end

    if not shouldAim then
        AimPart = nil
        return
    end

    local part = findClosestAimTarget()
    AimPart = part

    if AimPart then
        local smooth = getVal("Smoothing") or 0.12
        local lookAt = CFrame.new(Camera.CFrame.Position, AimPart.Position)
        Camera.CFrame = Camera.CFrame:Lerp(lookAt, smooth)
    end
end)

