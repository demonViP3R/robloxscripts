local function pressParryKey()
    local keyObj = Keybinds.Parry
    if not keyObj then return end
    local keyCode = keyObj:GetKey()
    if not keyCode then return end
    local vk
    if type(keyCode) == "number" then
        vk = keyCode
    elseif type(keyCode) == "string" then
        local keyMap = {
            ["F"] = 0x46, ["G"] = 0x47, ["H"] = 0x48,
            ["Q"] = 0x51, ["E"] = 0x45, ["R"] = 0x52,
            ["LeftShift"] = 0xA0, ["RightShift"] = 0xA1,
            ["LeftControl"] = 0xA2, ["RightControl"] = 0xA3,
            ["Space"] = 0x20, ["Tab"] = 0x09,
        }
        vk = keyMap[keyCode]
    end
    if vk then
        keypress(vk)
        wait(0.1)
        keyrelease(vk)
    end
end

local function doublePressParryKey()
