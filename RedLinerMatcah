local function doHop()
    local ctrlToSpace  = getVal("CtrlToSpaceDelay") or 0.12
    local ctrlRelease  = getVal("CtrlReleaseDelay") or 0.07
    local spaceRelease = getVal("SpaceReleaseDelay") or 0.05

    isHopping = true
    LastBunnyHopTime = tick()

    task.spawn(function()
        keypress(0xA2)
        wait(ctrlToSpace)
        keypress(0x20)
        wait(ctrlRelease)
        keyrelease(0xA2)
        wait(spaceRelease)
        keyrelease(0x20)

        if getVal("MovementDebug") then
            print(string.format("[BunnyHop] Hop sent — ctrl→space=%.2f ctrl_rel=%.2f space_rel=%.2f",
                ctrlToSpace, ctrlRelease, spaceRelease))
        end
        isHopping = false
    end)
end

local bunnyHopConn
bunnyHopConn = RunService.Heartbeat:Connect(function()
    if not getVal("BunnyHopEnabled") then
        prevVelY = 0
        return
    end
    if isHopping then return end
    if not isPlayerMoving() then prevVelY = 0; return end

    local now = tick()
    local minInterval = getVal("BunnyHopDelay") or 0.40
    local cooldownOk = (now - LastBunnyHopTime) >= minInterval

    if getVal("VelocityDetect") then
        local velY = getRootVelY()
        if velY == nil then prevVelY = 0; return end

        local wasFalling = prevVelY < -1
        local justLanded = wasFalling and velY >= -1

        if getVal("MovementDebug") then
            print(string.format("[BunnyHop] velY=%.3f prevVelY=%.3f justLanded=%s cooldown=%s",
                velY, prevVelY, tostring(justLanded), tostring(cooldownOk)))
        end

        if justLanded and cooldownOk then
            if getVal("MovementDebug") then print(">> VELOCITY LANDING — hopping") end
            doHop()
        end
        prevVelY = velY
    else
        prevVelY = 0
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local grounded = hum.FloorMaterial ~= Enum.Material.Air

        if getVal("MovementDebug") then
            print(string.format("[BunnyHop] timer mode — grounded=%s cooldown=%s",
                tostring(grounded), tostring(cooldownOk)))
        end

        if grounded and cooldownOk then
            if getVal("MovementDebug") then print(">> TIMER HOP — hopping") end
            doHop()
        end
    end
end)
