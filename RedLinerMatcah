local function updateParryHurtboxSize()
    if not getVal("ExpandParryHitbox") then
        if lastParryHurtboxPart and originalParryHurtboxSize then
            lastParryHurtboxPart.Size = originalParryHurtboxSize
        end
        lastParryHurtboxPart = nil
        originalParryHurtboxSize = nil
        return
    end

    local part = getParryHurtbox()
    if part and part:IsA("BasePart") then
        if part ~= lastParryHurtboxPart then
            originalParryHurtboxSize = part.Size
            lastParryHurtboxPart = part
        end
        local multiplier = getVal("ParryHitboxMultiplier") or 2.0
        part.Size = originalParryHurtboxSize * multiplier
    else
        lastParryHurtboxPart = nil
        originalParryHurtboxSize = nil
    end
end

