            [0x4D] = Enum.KeyCode.M, [0x4E] = Enum.KeyCode.N,
            [0x4F] = Enum.KeyCode.O, [0x50] = Enum.KeyCode.P,
            [0x51] = Enum.KeyCode.Q, [0x52] = Enum.KeyCode.R,
            [0x53] = Enum.KeyCode.S, [0x54] = Enum.KeyCode.T,
            [0x55] = Enum.KeyCode.U, [0x56] = Enum.KeyCode.V,
            [0x57] = Enum.KeyCode.W, [0x58] = Enum.KeyCode.X,
            [0x59] = Enum.KeyCode.Y, [0x5A] = Enum.KeyCode.Z,
            [0x20] = Enum.KeyCode.Space, [0x09] = Enum.KeyCode.Tab,
        }
        local keyEnum = vkMap[targetKey]
        if keyEnum and input.KeyCode == keyEnum then
            matches = true
        end
    elseif type(targetKey) == "string" then
        local keyMap = {
            ["MB1"] = Enum.UserInputType.MouseButton1,
            ["MB2"] = Enum.UserInputType.MouseButton2,
            ["MB3"] = Enum.UserInputType.MouseButton3,
        }
        local keyEnum = keyMap[targetKey]
        if keyEnum and input.UserInputType == keyEnum then
            matches = true
        end
    end

    if matches then
        AimlockToggleState = not AimlockToggleState
        if AimStatusLabel then
            AimStatusLabel:SetText(AimlockToggleState and "Status: Active" or "Status: Inactive")
        end
    end
end))

